#fcs 5.0.0
format { profile: chart; }
tempoMap {
    0beat -> 120bpm;
}
lines {
    line main {
        floorScale: 120px;
        scrollTempoMap {
            0beat -> 120bpm;
        }
    }
}
collections {
    notes {
        tap {
            id: "n";
            line: @main;
            gameplay.time: 2beat;
            gameplay.side: "above";
            presentation.positionX: 0px;
        };
    }
}
