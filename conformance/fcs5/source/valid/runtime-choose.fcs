#fcs 5.0.0
format { profile: chart; }
tempoMap {
    0beat -> 120bpm;
}
lines {
    line main {}
}
collections {
    notes {
        tap {
            line: @main;
            gameplay.time: 2beat;
            presentation.alpha: choose {
                when d < 100px => 1.0;
                else => 0.25;
            };
        };
    }
}
