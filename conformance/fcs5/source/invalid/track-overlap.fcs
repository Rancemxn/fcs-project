#fcs 5.0.0
format { profile: chart; }
tempoMap { 0beat -> 120bpm; }
lines {
    line main {
        tracks {
            track invalid -> alpha: float {
                segments {
                    [0s, 2s): 1.0 -> 0.5 using "linear";
                    [1s, 3s): 0.5 -> 0.0 using "linear";
                }
            }
        }
    }
}
